# Backend configuration
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# Database provider selection: mysql or oracle
# Use mysql for MySQL and oracle for Oracle database connections.
DB_PROVIDER=mysql
DATABASE_URL=
# Alternative DB settings (used when DATABASE_URL is not set)
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=
# Oracle-specific options (used when DB_PROVIDER=oracle and DATABASE_URL is not set)
DB_SERVICE=xe

# App/ports
PORT=8000
BACKEND_BASE_URL=http://127.0.0.1:8000

# LLM provider selection: groq or local
# Use groq for Groq cloud models or local for a local LLM endpoint such as Ollama.
LLM_PROVIDER=groq
GRAQ_API_URL=https://api.groq.com/openai/v1
GRAQ_API_KEY=
GRAQ_MODEL=llama-3.1-8b-instant
LOCAL_LLM_URL=http://127.0.0.1:11434/v1/chat/completions
LOCAL_LLM_MODEL=phi3

# Optional frontend origin for CORS if needed
FRONTEND_URL=http://localhost:3000
